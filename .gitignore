# Fetched/imported runs (local working data, not shared)
runs/
runs-local/

# Session transcripts live in S3 and must never be committed
/sessions/

# AgentsView runtime configuration contains generated secrets
/agentsview-s3.toml

# Local AgentsView checkout and SQLite runtime state
/agentsview/
/sessions.db-*

# Generated Python packaging metadata
*.egg-info/

# Python bytecode cache
__pycache__/
